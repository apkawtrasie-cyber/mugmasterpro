# ─────────────────────────────────────────────────────────────────────────────
# MugMaster Pro — environment variables template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Public app URL (used for Open Graph tags, share links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name shown in metadata
NEXT_PUBLIC_APP_NAME=MugMaster Pro
